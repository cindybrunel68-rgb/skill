# AI OS (Local Edition) — Environment Variables
# Copy this file to .env and fill in only the keys you need.
#
# THE CORE WORKS WITH ZERO KEYS. You only need a Claude Code subscription
# (the `claude` CLI logged into your Claude account). The keys below unlock
# OPTIONAL skills that talk to third-party services. Add them only when you
# actually use the matching skill.

# ============================================================
# General
# ============================================================

# Your timezone, e.g. Europe/Paris, America/New_York, Asia/Tokyo
TIMEZONE=UTC

# ============================================================
# OPTIONAL — per-skill API keys (uncomment + fill as needed)
# ============================================================

# Research — Perplexity (skills: research, research-lead, meeting-prep)
# PERPLEXITY_API_KEY=

# Advanced memory — mem0 + Pinecone (skill: memory). Fully optional.
# The default memory is file-based and needs no keys. See docs/MEMORY-UPGRADE.md.
# OPENAI_API_KEY=
# PINECONE_API_KEY=
# MEM0_USER_ID=your_name

# Lead generation (skill: research-lead)
# OPENAI_API_KEY=        # also reused for the AI analysis step
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=

# Slack notifications (skill: email-digest)
# SLACK_BOT_TOKEN=
# SLACK_CHANNEL_ID=

# Todoist (skill: scrum-master, via MCP)
# TODOIST_API_KEY=

# Notion (via MCP)
# NOTION_TOKEN=

# Google Calendar & Gmail (skill: google-workspace-setup, or use Claude connectors)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# Slide generation (skill: gamma-slides)
# GAMMA_API_KEY=
